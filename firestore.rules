rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sessions sub-collection:
      //   - Owner (MT) has full access
      //   - Linked PS can read
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedMtId == userId;
      }
    }

    // Invites:
    //   - Any authenticated user can create
    //   - MT (by mtId) and PS (by psEmail) can read and update their invites
    match /invites/{inviteId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && (resource.data.mtId == request.auth.uid
            || resource.data.psEmail == request.auth.token.email);
    }
  }
}
